{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-spec",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "@geoicons/angular": ["./src/public-api.ts"]
    }
  },
  "angularCompilerOptions": {
    "compilationMode": "full",
    "strictTemplates": true
  },
  "include": ["src/**/*.ts", "countries/**/*.ts", "areas/**/*.ts"]
}
